  <remove-project name="platform/external/elfutils" path="external/elfutils" />
  <remove-project
    name="platform/external/googletest"
    path="external/googletest"
  />
  <remove-project
    name="platform/external/rust/android-crates-io"
    path="external/rust/android-crates-io"
  />
  <remove-project
    name="platform/external/rust/crates/smoltcp"
    path="external/rust/crates/smoltcp"
  />
